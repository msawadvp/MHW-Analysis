import numpy as np
import matplotlib.pyplot as plt

# ======================================================
# PATHS
# ======================================================

AS = "/home/sriram/Internship/Arabian_Sea_Decadal_MHW_Metrics"
BoB = "/home/sriram/Internship/Bay_of_Bengal_Decadal_MHW_Metrics"

# ======================================================
# HELPER FUNCTION
# ======================================================

def basin_mean(file):
    return np.nanmean(np.load(file))

def pct_change(old, new):
    return ((new - old) / old) * 100

# ======================================================
# LOAD FREQUENCY
# ======================================================

AS_freq = [
    basin_mean(f"{AS}/freq_1993_2003.npy"),
    basin_mean(f"{AS}/freq_2004_2014.npy"),
    basin_mean(f"{AS}/freq_2015_2025.npy")
]

BoB_freq = [
    basin_mean(f"{BoB}/freq_1993_2003.npy"),
    basin_mean(f"{BoB}/freq_2004_2014.npy"),
    basin_mean(f"{BoB}/freq_2015_2025.npy")
]

# ======================================================
# LOAD DURATION
# ======================================================

AS_dur = [
    basin_mean(f"{AS}/dur_1993_2003.npy"),
    basin_mean(f"{AS}/dur_2004_2014.npy"),
    basin_mean(f"{AS}/dur_2015_2025.npy")
]

BoB_dur = [
    basin_mean(f"{BoB}/dur_1993_2003.npy"),
    basin_mean(f"{BoB}/dur_2004_2014.npy"),
    basin_mean(f"{BoB}/dur_2015_2025.npy")
]

# ======================================================
# LOAD CUMULATIVE INTENSITY
# ======================================================

AS_cum = [
    basin_mean(f"{AS}/cum_1993_2003.npy"),
    basin_mean(f"{AS}/cum_2004_2014.npy"),
    basin_mean(f"{AS}/cum_2015_2025.npy")
]

BoB_cum = [
    basin_mean(f"{BoB}/cum_1993_2003.npy"),
    basin_mean(f"{BoB}/cum_2004_2014.npy"),
    basin_mean(f"{BoB}/cum_2015_2025.npy")
]

# ======================================================
# PERCENTAGE CHANGE
# ======================================================

AS_EM = [
    pct_change(AS_freq[0], AS_freq[1]),
    pct_change(AS_dur[0], AS_dur[1]),
    pct_change(AS_cum[0], AS_cum[1]),
]

BoB_EM = [
    pct_change(BoB_freq[0], BoB_freq[1]),
    pct_change(BoB_dur[0], BoB_dur[1]),
    pct_change(BoB_cum[0], BoB_cum[1]),
]

AS_MR = [
    pct_change(AS_freq[1], AS_freq[2]),
    pct_change(AS_dur[1], AS_dur[2]),
    pct_change(AS_cum[1], AS_cum[2]),
]

BoB_MR = [
    pct_change(BoB_freq[1], BoB_freq[2]),
    pct_change(BoB_dur[1], BoB_dur[2]),
    pct_change(BoB_cum[1], BoB_cum[2]),
]

# ======================================================
# PLOT SETTINGS
# ======================================================

plt.rcParams.update({
    "font.size": 11,
    "axes.titlesize": 12,
    "axes.labelsize": 11
})

metrics = ["Frequency", "Duration", "Cumulative Intensity"]

fig, axes = plt.subplots(
    3, 2,
    figsize=(12, 10),
    constrained_layout=True
)

# ======================================================
# PLOTTING
# ======================================================

for i, metric in enumerate(metrics):

    # -----------------------------------
    # Early → Middle
    # -----------------------------------

    ax = axes[i, 0]

    vals = [AS_EM[i], BoB_EM[i]]

    bars = ax.bar(
        ["Arabian Sea", "Bay of Bengal"],
        vals,
        color=["red", "blue"],
        width=0.4
    )

    ax.axhline(0, color="black", linewidth=1)

    ax.set_title(f"{metric}\nEarly → Middle")
    ax.set_ylabel("% Change")

    ax.grid(
        True,
        axis="y",
        linestyle="--",
        alpha=0.4
    )

    for b in bars:

        h = b.get_height()

        offset = 1 if h >= 0 else -3

        ax.text(
            b.get_x() + b.get_width()/2,
            h + offset,
            f"{h:.1f}%",
            ha="center",
            fontsize=9,
            fontweight="bold"
        )

    # -----------------------------------
    # Middle → Recent
    # -----------------------------------

    ax = axes[i, 1]

    vals = [AS_MR[i], BoB_MR[i]]

    bars = ax.bar(
        ["Arabian Sea", "Bay of Bengal"],
        vals,
        color=["red", "blue"],
        width=0.4
    )

    ax.axhline(0, color="black", linewidth=1)

    ax.set_title(f"{metric}\nMiddle → Recent")
    ax.set_ylabel("% Change")

    ax.grid(
        True,
        axis="y",
        linestyle="--",
        alpha=0.4
    )

    for b in bars:

