
'''
INDEPENDENT SUBSURFACE MHW DETECTION
Region: Arabian Sea
Data: GLORYS Temperature (thetao)
'''

import numpy as np
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
from scipy.ndimage import gaussian_filter
import marineHeatWaves as mhw
import xarray as xr
import os
import time
import warnings

warnings.filterwarnings('ignore')


# CONFIGURATION (CHANGE THESE)
class Config:
    
    TARGET_DEPTH = 130 #change to 25,55,66,78,109,131,155 later
    
    #  FILE PATHS
    GLORYS_FILE = "File Name"
    OUTPUT_DIR  = "Direction"
    
    # REGION (Bay of Bengal),Change Accordingly
    LAT_MIN, LAT_MAX = 5, 23
    LON_MIN, LON_MAX = 80, 100
    
    # TIME PERIODS
    # Climatology for Threshold (Standard 30-year)
    CLIM_START = 1993
    CLIM_END   = 2022
    
    # Analysis Period for Metrics (Full dataset)
    ANALYSIS_START = 1993
    ANALYSIS_END   = 2025
    
    # MHW PARAMETERS (Hobday et al. 2016)
    PCTILE           = 90
    WINDOW_HALF_W    = 5
    SMOOTH_WIDTH     = 31
    MIN_DURATION     = 5
    MAX_GAP          = 2
    
    # QUALITY CONTROL
    TEMP_MIN = -2.0   # Min realistic temp
    TEMP_MAX = 35.0   # Max realistic temp
    GAP_LIMIT = 0.2   # Max 20% missing data allowed

config = Config()
os.makedirs(config.OUTPUT_DIR, exist_ok=True)


# 1. LOAD DATA


print(f"LOADING DATA: Depth = {config.TARGET_DEPTH}m")


start_load = time.time()

try:
    # Open with lazy loading to save memory
    ds = xr.open_dataset(config.GLORYS_FILE, chunks={'time': 365})
    
    # Check coordinate names (GLORYS varies)
    lat_name = 'latitude' if 'latitude' in ds.dims else 'lat'
    lon_name = 'longitude' if 'longitude' in ds.dims else 'lon'
    depth_name = 'depth'
    
    # Select Region & Time
    ds_subset = ds.sel(
        {lat_name: slice(config.LAT_MIN, config.LAT_MAX),
         lon_name: slice(config.LON_MIN, config.LON_MAX)}
    )
    
    # Extract Temperature Variable

    temp_var = ds_subset['thetao']
        
    # Extract Coordinates
    lat = ds_subset[lat_name].values
    lon = ds_subset[lon_name].values
    depth_levels = ds_subset[depth_name].values
    time_coords = ds_subset['time'].values
    
    # Find Target Depth Index
    depth_idx = np.argmin(np.abs(depth_levels - config.TARGET_DEPTH))
    actual_depth = depth_levels[depth_idx]
    print(f"Target: {config.TARGET_DEPTH}m -> Found GLORYS Level: {actual_depth:.2f}m")
    
    # Extract 2D Slice (Time, Lat, Lon)
    # Transpose to (time, lat, lon) for easier looping
    temp_2d = temp_var.isel(depth=depth_idx).values
    
    print(f"Data Loaded. Shape: {temp_2d.shape}")
    ds.close() # Close file handle
    
except Exception as e:
    print(f"\nâŒ ERROR LOADING DATA: {e}")
    exit()

print(f"Load time: {time.time() - start_load:.2f}s")


# 2. TIME CONVERSION

print("\nConverting time to ordinal...")
from datetime import datetime

# Handle various time formats safely
try:
    t_ordinal = np.array([
        datetime.utcfromtimestamp(t.astype('datetime64[s]').astype(int)).toordinal() 
        for t in time_coords
    ])
except:
    # Fallback for pandas datetime objects
    t_ordinal = np.array([pd.to_datetime(t).toordinal() for t in time_coords])

# Calculate Analysis Years
analysis_years = config.ANALYSIS_END - config.ANALYSIS_START + 1


# 3. GRID-WISE MHW DETECTION

print("DETECTING MHWs GRID-WISE")


nlat, nlon = len(lat), len(lon)

# Initialize Metric Arrays
metric_freq    = np.full((nlat, nlon), np.nan)
metric_dur     = np.full((nlat, nlon), np.nan)
metric_days    = np.full((nlat, nlon), np.nan)
metric_cumint  = np.full((nlat, nlon), np.nan)

start_detect = time.time()
total_cells = nlat * nlon
count = 0

for i in range(nlat):
    for j in range(nlon):
        count += 1
        
        # Progress Bar
        if count % 1000 == 0:
            print(f"Progress: {count}/{total_cells} ({count/total_cells*100:.1f}%)")
        
        # Extract Time Series
        ts = temp_2d[:, i, j]
        
        # 1. Quality Check: Skip Land/All-NaN
        if np.all(np.isnan(ts)):
            continue
            
        # 2. Valid Data Fraction Check
        valid_frac = np.sum(~np.isnan(ts)) / len(ts)
        if valid_frac < 0.8:
            continue
            
        # 3. Fill Small Gaps
        nan_mask = np.isnan(ts)
        gap_frac = np.sum(nan_mask) / len(ts)
        if 0 < gap_frac < config.GAP_LIMIT:
            indices = np.arange(len(ts))
            ts[nan_mask] = np.interp(indices[nan_mask], indices[~nan_mask], ts[~nan_mask])
        
        # 4. Detect MHW
        try:
            mhws, clim = mhw.detect(
                t_ordinal, ts,
                climatologyPeriod=[config.CLIM_START, config.CLIM_END],
                pctile=config.PCTILE,
                windowHalfWidth=config.WINDOW_HALF_W,
                smoothPercentile=True,
                smoothPercentileWidth=config.SMOOTH_WIDTH,
                minDuration=config.MIN_DURATION,
                joinAcrossGaps=True,
                maxGap=config.MAX_GAP
            )
            
            n_events = mhws['n_events']
            
            if n_events > 0:
                metric_freq[i, j]   = n_events / analysis_years
                metric_dur[i, j]    = np.mean(mhws['duration'])
                metric_days[i, j]   = np.sum(mhws['duration']) / analysis_years
                metric_cumint[i, j] = np.sum(mhws['intensity_cumulative']) / analysis_years
                
        except Exception:
            continue

print(f"\nDetection complete in {time.time() - start_detect:.2f}s")


# 4. MASKED SMOOTHING (For Visualization Only)

print("\nApplying Masked Smoothing...")

def smooth_with_mask(data, sigma=1):
    """
    Properly smooths ocean pixels, avoiding land contamination.
    """
    mask = np.isnan(data)
    filled = np.where(mask, 0, data)
    
    smooth_data = gaussian_filter(filled, sigma=sigma)
    smooth_mask = gaussian_filter((~mask).astype(float), sigma=sigma)
    
    with np.errstate(divide='ignore', invalid='ignore'):
        result = smooth_data / smooth_mask
    
    result[mask] = np.nan
    return result

smooth_freq   = smooth_with_mask(metric_freq, sigma=1)
smooth_dur    = smooth_with_mask(metric_dur, sigma=1)
smooth_days   = smooth_with_mask(metric_days, sigma=1)
smooth_cumint = smooth_with_mask(metric_cumint, sigma=1)


# 5. PLOTTING

print("\nGenerating Figure...")

fig, axes = plt.subplots(2, 2, figsize=(14, 10), subplot_kw={'projection': ccrs.PlateCarree()})
axes = axes.flatten()

metrics = [
    (smooth_freq,  '(a) Frequency',         'events/year',   'YlOrBr'),
    (smooth_dur,   '(b) Duration',          'days/event',    'YlOrBr'),
    (smooth_days,  '(c) Total Days',        'days/year',     'YlOrBr'),
    (smooth_cumint,'(d) Cumulative Intensity', '°C·days/year', 'YlOrBr')
]

for ax, (data_arr, title, label, cmap) in zip(axes, metrics):
    # Set Extent
    ax.set_extent([config.LON_MIN, config.LON_MAX, config.LAT_MIN, config.LAT_MAX])
    
    # Add Features
    ax.add_feature(cfeature.COASTLINE, linewidth=0.8)
    ax.add_feature(cfeature.LAND, color='lightgray', alpha=0.5)
    
    # Levels
    valid_data = data_arr[~np.isnan(data_arr)]
    if len(valid_data) > 0:
        vmin = np.nanpercentile(valid_data, 5)
        vmax = np.nanpercentile(valid_data, 95)
        levels = np.linspace(vmin, vmax, 30)
        
        cf = ax.contourf(lon, lat, data_arr, levels=levels, cmap=cmap, 
                         extend='both', transform=ccrs.PlateCarree())
        cbar = fig.colorbar(cf, ax=ax, label=label, shrink=0.8)
    
    # Labels
    ax.set_title(title, fontsize=12, fontweight='bold')
    ax.gridlines(draw_labels=True, linewidth=0.5, alpha=0.3, linestyle='--')

plt.suptitle(f"Subsurface MHW Metrics at {actual_depth:.1f}m ({config.ANALYSIS_START}-{config.ANALYSIS_END})", 
             fontsize=15, fontweight='bold')
plt.tight_layout()

# Saving
out_file = os.path.join(config.OUTPUT_DIR, f"MHW_Metrics_{int(actual_depth)}m.png")
plt.savefig(out_file, dpi=300, bbox_inches='tight')
print(f"Saved: {out_file}")
plt.show()

# 6. SAVE ARRAYS

np.save(os.path.join(config.OUTPUT_DIR, f'metric_freq_{actual_depth:.1f}m.npy'), metric_freq)
np.save(os.path.join(config.OUTPUT_DIR, f'metric_dur_{actual_depth:.1f}m.npy'), metric_dur)
np.save(os.path.join(config.OUTPUT_DIR, f'metric_days_{actual_depth:.1f}m.npy'), metric_days)
np.save(os.path.join(config.OUTPUT_DIR, f'metric_cumint_{actual_depth:.1f}m.npy' ), metric_cumint)
print("\nâœ… Analysis Complete. Results Saved.")
